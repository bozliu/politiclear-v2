{
  "name": "politiclear-app",
  "version": "1.0.0",
  "license": "Apache-2.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "npx expo export --platform web --output-dir dist",
    "build:vercel": "npm run verify:bundle && npm run build:web",
    "api": "node server/index.js",
    "ingest:data": "conda run -n dl python scripts/ingest/build_politiclear_data.py",
    "sync:boundaries": "conda run -n dl python scripts/ingest/sync_boundaries_only.py",
    "verify:bundle": "node scripts/verify_bundle.mjs",
    "prepare:data": "npm run ingest:data && npm run sync:boundaries && npm run verify:bundle",
    "preflight:preview": "npm run prepare:data && npm run build:web",
    "package:preview": "npm run build:web && bash scripts/package_preview_tarball.sh",
    "package:preview:fresh-data": "npm run preflight:preview && bash scripts/package_preview_tarball.sh",
    "validate:release:api": "node scripts/validate_release_api.mjs",
    "validate:release:ui": "node scripts/validate_release_ui.mjs",
    "validate:preview": "node scripts/validate_preview.mjs",
    "validate:canonical": "node scripts/validate_canonical.mjs",
    "deploy:live": "bash scripts/deploy_latest_preview.sh",
    "deploy:live:fresh-data": "bash scripts/deploy_latest_preview.sh",
    "deploy:preview": "POLITICLEAR_EXPECT_CANONICAL_STAGE=public-beta POLITICLEAR_EXPECT_DEPLOY_STAGE=public-beta bash scripts/deploy_latest_preview.sh",
    "deploy:preview:fresh-data": "POLITICLEAR_EXPECT_CANONICAL_STAGE=public-beta POLITICLEAR_EXPECT_DEPLOY_STAGE=public-beta bash scripts/deploy_latest_preview.sh",
    "deploy:preview:quick": "POLITICLEAR_EXPECT_CANONICAL_STAGE=public-beta POLITICLEAR_EXPECT_DEPLOY_STAGE=public-beta PREVIEW_SKIP_DATA_REFRESH=1 bash scripts/deploy_latest_preview.sh",
    "deploy:preview:claimable": "bash scripts/deploy_claimable_preview.sh"
  },
  "dependencies": {
    "@expo/metro-runtime": "~3.1.3",
    "@react-navigation/bottom-tabs": "^6.5.12",
    "@react-navigation/native": "^6.1.10",
    "@react-navigation/stack": "^6.3.21",
    "cors": "^2.8.6",
    "expo": "~50.0.7",
    "expo-image": "~1.10.6",
    "expo-status-bar": "~1.11.1",
    "express": "^4.22.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.73.4",
    "react-native-gesture-handler": "~2.14.0",
    "react-native-safe-area-context": "4.8.2",
    "react-native-screens": "~3.29.0",
    "react-native-svg": "14.1.0",
    "react-native-swiper": "^1.6.0",
    "react-native-web": "~0.19.6",
    "recoil": "^0.7.7"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@playwright/test": "^1.58.2"
  },
  "private": true
}
